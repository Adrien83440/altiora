rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ═══════════════════════════════════════════════════════════════
    // HELPERS
    // ═══════════════════════════════════════════════════════════════
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    // ─── Admin (serveur + équipe Alteore) ──────────────────────────
    function isAdmin() {
      return isAuth() && (
        request.auth.token.email == 'api@altiora.app'
        || request.auth.token.email == 'contact@adrienemily.com'
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
        )
      );
    }
    function getUserPlan(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.plan;
    }
    function hasPaidPlan(uid) {
      return getUserPlan(uid) in ['pro', 'max', 'master', 'trial'];
    }
    function hasFidelitePlan(uid) {
      return getUserPlan(uid) in ['max', 'master', 'trial'];
    }
    function hasRhPlan(uid) {
      return getUserPlan(uid) in ['master', 'trial'];
    }
    function hasBilanPlan(uid) {
      return getUserPlan(uid) in ['max', 'master', 'trial'];
    }
    // ─── Conseiller avec accès actif au compte client ──────────────
    // Utilisé pour autoriser un comptable/coach à LIRE (jamais écrire)
    // les données financières d'un client qui l'a invité.
    //
    // Protection : exists() pour ne pas crasher si le grant n'existe pas,
    // status='active' (vs 'revoked' ou 'expired'),
    // expiresAt null (= permanent) OU dans le futur.
    //
    // Le conseillerUid utilisé comme clé du grant = request.auth.uid.
    // ───────────────────────────────────────────────────────────────
    function isConseillerWithGrant(clientUid) {
      return isAuth()
        && exists(/databases/$(database)/documents/client_access/$(clientUid)/grants/$(request.auth.uid))
        && get(/databases/$(database)/documents/client_access/$(clientUid)/grants/$(request.auth.uid)).data.status == 'active'
        && (
          get(/databases/$(database)/documents/client_access/$(clientUid)/grants/$(request.auth.uid)).data.expiresAt == null
          || get(/databases/$(database)/documents/client_access/$(clientUid)/grants/$(request.auth.uid)).data.expiresAt > request.time
        );
    }
    // ═══════════════════════════════════════════════════════════════
    // USERS
    //
    // Lecture : owner, admin, OU conseiller avec grant
    //   (le conseiller a besoin de lire users/{clientUid} pour que
    //    nav.js récupère le plan et configure correctement l'UI)
    // Écriture : owner pour champs non-sensibles, admin pour le reste.
    //
    // 🔒 Correctif C1/C2 (audit 13/07/2026) :
    //  - create : le user ne peut se créer qu'avec plan ∈ {free, trial}
    //    et ne peut PAS poser role / agentEnabled / betaTester
    //    (sinon : auto-attribution d'un plan payant + Léa gratuite).
    //  - update : role / agentEnabled / betaTester ajoutés aux champs
    //    interdits (sinon : élévation admin en 1 ligne de console →
    //    isAdmin() devient vrai → accès total à TOUS les comptes).
    // ═══════════════════════════════════════════════════════════════
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin() || isConseillerWithGrant(uid);
      allow create: if isAdmin()
        || (isOwner(uid)
            && request.resource.data.get('plan', 'free') in ['free', 'trial']
            && !request.resource.data.keys().hasAny(['role', 'agentEnabled', 'betaTester']));
      allow update: if isAdmin()
        || (isOwner(uid)
            && !('plan'                 in request.resource.data.diff(resource.data).affectedKeys())
            && !('stripeCustomerId'     in request.resource.data.diff(resource.data).affectedKeys())
            && !('stripeSubscriptionId' in request.resource.data.diff(resource.data).affectedKeys())
            && !('trialEnd'             in request.resource.data.diff(resource.data).affectedKeys())
            && !('role'                 in request.resource.data.diff(resource.data).affectedKeys())
            && !('agentEnabled'         in request.resource.data.diff(resource.data).affectedKeys())
            && !('betaTester'           in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // USERS_ACTIVITY — Tracking connexions / activité / modules
    // ═══════════════════════════════════════════════════════════════
    match /users_activity/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // PROFIL ENTREPRISE
    // Lecture étendue au conseiller (contexte entreprise utile)
    // ═══════════════════════════════════════════════════════════════
    match /profil/{uid}/{allPaths=**} {
      allow read:  if isOwner(uid) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if isOwner(uid) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // PILOTAGE
    // Split read/write : lecture étendue au conseiller, écriture inchangée
    //
    // - months         : données mensuelles (CA, charges, crédits, leasing)
    // - cartes_cadeaux : cartes cadeaux vendues (CA différé, doc `all`)
    // ═══════════════════════════════════════════════════════════════
    match /pilotage/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      match /months/{month} {
        allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
        allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
      match /cartes_cadeaux/{docId} {
        allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
        allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // MARGES
    // ═══════════════════════════════════════════════════════════════
    match /marges/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      match /produits/{itemId} {
        allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
        allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
      match /params/{itemId} {
        allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
        allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // PRODUITS / COUT DE REVIENT
    //
    // - items   : recettes / produits du catalogue
    // - meta    : métadonnées du catalogue (ex: doc `categories` contenant
    //             la liste des catégories manuelles définies par l'user)
    // ═══════════════════════════════════════════════════════════════
    match /produits/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      match /items/{itemId} {
        allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
        allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
      match /meta/{docId} {
        allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
        allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // FICHES FOURNISSEURS — Coût de revient (fournisseurs + articles)
    //
    // Utilisé par cout-revient.html et import-facture-achat.html
    // pour stocker les fournisseurs et leurs catalogues d'articles.
    // Path : fiches/{uid}/items/{fournisseurId}
    // ═══════════════════════════════════════════════════════════════
    match /fiches/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      match /items/{itemId} {
        allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
        allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // PANIER MOYEN
    // ═══════════════════════════════════════════════════════════════
    match /panier/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      match /data/{docId} {
        allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
        allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // DETTES
    // ═══════════════════════════════════════════════════════════════
    match /dettes/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      match /data/{docId} {
        allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
        allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // CASHFLOW
    // ═══════════════════════════════════════════════════════════════
    match /cashflow/{uid}/{allPaths=**} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // PREVISIONS — Module de prévisions hebdo/mensuelles (plan master)
    //
    // - config/settings    : paramétrage du module
    // - predictions/{wk}   : prévisions par semaine ISO
    // - historique/{mk}    : historique mensuel pour entraîner les prédictions
    //
    // Note : le cron-trial-check liste `previsions` dans SIMPLE_DOCS pour
    // suppression — ce fix permet à la fois l'usage normal et la suppression.
    // ═══════════════════════════════════════════════════════════════
    match /previsions/{uid}/{allPaths=**} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
    }
    match /previsions/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // CATALOGUES — Listes d'autocomplete pour pilotage
    // (fournisseurs, clients, descriptions, types de charges)
    //
    // Path : catalogues/{uid}  (doc unique par utilisateur)
    // Lecture conseiller : utile pour comprendre la classification
    // ═══════════════════════════════════════════════════════════════
    match /catalogues/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // SUPPLIERS — LEGACY (ancien stockage fournisseurs pilotage)
    //
    // Conservé en lecture pour permettre la migration vers `catalogues`
    // (pilotage.html lit `suppliers` si `catalogues` est vide).
    // Écriture interdite, suppression par admin (cron-trial-check).
    // Path : suppliers/{uid}
    // ═══════════════════════════════════════════════════════════════
    match /suppliers/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      allow write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // FOURNISSEURS — Fiches fournisseurs du Pilotage (doc unique {list})
    //
    // Utilisé par pilotage.html (onglet « Fiches » du catalogue
    // fournisseurs, loadFiches/saveFiches) et suivi-ca.html (lecture).
    // Collection distincte de `fiches` (coût de revient) et de
    // `catalogues` (autocomplete).
    // Path : fournisseurs/{uid} → { list: [...] }
    //
    // ⚠️ Sans ce bloc, la collection tombait dans le REFUS PAR DEFAUT :
    // la sauvegarde de fiche fournisseur échouait silencieusement en
    // prod (catch → console.warn / toast « Erreur sauvegarde fiche »).
    // ═══════════════════════════════════════════════════════════════
    match /fournisseurs/{uid} {
      allow read:  if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // COPILOTE IA — LEGACY
    // ═══════════════════════════════════════════════════════════════
    match /copilote/{uid}/{allPaths=**} {
      allow read, write: if (isOwner(uid) && hasFidelitePlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // AGENT IA — Léa
    // (PAS d'accès conseiller — Léa est exclue du périmètre conseil)
    // ═══════════════════════════════════════════════════════════════
    match /agent/{uid}/{allPaths=**} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // BILANS IA
    // Le conseiller peut lire les bilans (utile pour comptable surtout)
    // ═══════════════════════════════════════════════════════════════
    match /bilans/{uid}/{allPaths=**} {
      allow read:  if (isOwner(uid) && hasBilanPlan(uid)) || isAdmin() || isConseillerWithGrant(uid);
      allow write: if (isOwner(uid) && hasBilanPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // CONNEXIONS BANCAIRES (GoCardless)
    // ═══════════════════════════════════════════════════════════════
    match /bank_connections/{uid} {
      allow read, write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      match /banks/{bankId} {
        allow read, write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // TRANSACTIONS BANCAIRES EN ATTENTE
    // ═══════════════════════════════════════════════════════════════
    match /bank_pending/{uid} {
      allow read, write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // BANK_RULES — Règles de catégorisation auto des transactions
    //
    // Utilisé par bank-validation.html pour mémoriser les patterns
    // de catégorisation appris (libellé → catégorie/type/fournisseur).
    // Path : bank_rules/{uid}
    // ═══════════════════════════════════════════════════════════════
    match /bank_rules/{uid} {
      allow read, write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // STOCK
    // ═══════════════════════════════════════════════════════════════
    match /stock/{uid}/{allPaths=**} {
      allow read, write: if (isOwner(uid) && hasPaidPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // FIDELISATION
    // ═══════════════════════════════════════════════════════════════
    match /fidelite/{uid} {
      allow read, write: if (isOwner(uid) && hasFidelitePlan(uid)) || isAdmin();
      match /{subcollection}/{docId} {
        allow read, write: if (isOwner(uid) && hasFidelitePlan(uid)) || isAdmin();
      }
    }
    match /fidelite_public/{clientId} {
      allow read: if true;
      allow create: if (isAuth() && hasFidelitePlan(request.auth.uid)) || isAdmin();
      allow update: if isAdmin()
        || (isAuth()
            && hasFidelitePlan(request.auth.uid)
            && resource.data.merchantUid == request.auth.uid);
      allow delete: if isAdmin()
        || (isAuth()
            && hasFidelitePlan(request.auth.uid)
            && resource.data.merchantUid == request.auth.uid);
    }
    match /fidelite_public_cfg/{uid} {
      allow read: if true;
      allow write: if (isOwner(uid) && hasFidelitePlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // FIDELITE_TABLET — Tablette commerçant (page non authentifiée)
    //
    // tablet.html prend ?m=merchantUid en URL et écrit/lit sans
    // Firebase Auth. Lecture/écriture publique nécessaire.
    // Path : fidelite_tablet/{merchantUid}/clients/{clientId}
    // ═══════════════════════════════════════════════════════════════
    match /fidelite_tablet/{merchantUid} {
      allow read, write: if true;
      match /clients/{clientId} {
        allow read, write: if true;
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // SMS CREDITS
    // ═══════════════════════════════════════════════════════════════
    match /sms_credits/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
      match /{subcollection}/{docId} {
        allow read:  if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // RH
    // ═══════════════════════════════════════════════════════════════
    match /rh/{uid}/{allPaths=**} {
      allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — ESPACE SALARIE PUBLIC
    // ═══════════════════════════════════════════════════════════════
    match /rh_employes_public/{publicId} {
      allow read:   if true;
      allow create: if (isAuth() && hasRhPlan(request.auth.uid)) || isAdmin();
      allow update: if (isAuth() && hasRhPlan(request.auth.uid)) || isAdmin();
      allow delete: if (isAuth() && hasRhPlan(request.auth.uid)) || isAdmin();
    }
    match /rh_employes_public_profil/{publicId} {
      allow read:   if true;
      allow create: if (isAuth() && hasRhPlan(request.auth.uid)) || isAdmin();
      allow update: if (isAuth() && hasRhPlan(request.auth.uid)) || isAdmin();
      allow delete: if (isAuth() && hasRhPlan(request.auth.uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — AUTHENTIFICATION SALARIES (PIN, lockouts, reset codes)
    // ═══════════════════════════════════════════════════════════════
    match /rh_auth_salaries/{publicId} {
      allow read, write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — PLANNING PUBLIC
    // ═══════════════════════════════════════════════════════════════
    match /rh_planning_public/{uid}/{allPaths=**} {
      allow read:  if true;
      allow write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — PARAMETRES GENERAUX
    // ═══════════════════════════════════════════════════════════════
    match /rh_params/{uid} {
      allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — CONGES (admin)
    // ═══════════════════════════════════════════════════════════════
    match /rh_conges/{uid} {
      allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      match /demandes/{demandeId} {
        allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — CONGES PUBLIC (espace salarié, pas d'auth Firebase)
    //
    // L'employé soumet ses demandes via espace-salarie.html (non auth).
    // Lecture/écriture publique nécessaire ; les données sont scopées
    // par {uid} et un attaquant n'a aucun moyen de connaître les uids.
    // Path : rh_conges_public/{uid}/demandes/{demandeId}
    // ═══════════════════════════════════════════════════════════════
    match /rh_conges_public/{uid} {
      allow read, write: if true;
      match /demandes/{demandeId} {
        allow read, write: if true;
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — ONBOARDING
    // ═══════════════════════════════════════════════════════════════
    match /rh_onboarding/{uid} {
      allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      match /dossiers/{dossierId} {
        allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — RECRUTEMENT
    // ═══════════════════════════════════════════════════════════════
    match /rh_recrutement/{uid} {
      allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      match /offres/{offreId} {
        allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      }
      match /candidats/{candidatId} {
        allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      }
      match /entretiens/{entretienId} {
        allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — DOCUMENTS GENERES
    // ═══════════════════════════════════════════════════════════════
    match /rh_docs_gen/{uid} {
      allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      match /items/{itemId} {
        allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — EMARGEMENTS (admin)
    //
    // Fiches d'émargement légales générées depuis le planning.
    // Lues par rh-emargements.html (employeur, authentifié).
    // Path : rh_emargements/{uid}/{fiches|daily|planning_acks}/{id}
    // ═══════════════════════════════════════════════════════════════
    match /rh_emargements/{uid}/{allPaths=**} {
      allow read, write: if (isOwner(uid) && hasRhPlan(uid)) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — EMARGEMENTS PUBLIC (espace salarié, pas d'auth Firebase)
    //
    // Signatures électroniques des fiches d'émargement par les
    // salariés depuis espace-salarie.html (non authentifié Firebase).
    // Path : rh_emargements_public/{uid}/signatures/{sigId}
    // ═══════════════════════════════════════════════════════════════
    match /rh_emargements_public/{uid} {
      allow read, write: if true;
      match /signatures/{sigId} {
        allow read, write: if true;
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — OBJECTIFS PUBLIC (espace salarié)
    //
    // Objectifs assignés aux salariés, écrits par rh-objectifs.html
    // (employeur authentifié) ET lus par espace-salarie.html (non auth).
    // Path : rh_objectifs_public/{uid}/items/{itemId}
    // ═══════════════════════════════════════════════════════════════
    match /rh_objectifs_public/{uid} {
      allow read, write: if true;
      match /items/{itemId} {
        allow read, write: if true;
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // RH — POINTAGES PUBLIC (espace salarié)
    //
    // Pointages enregistrés par le salarié depuis espace-salarie.html
    // (non authentifié). Lus par rh-pointages.html (employeur).
    // Path : rh_pointages_public/{uid}/events/{dateKey}
    // ═══════════════════════════════════════════════════════════════
    match /rh_pointages_public/{uid} {
      allow read, write: if true;
      match /events/{dateKey} {
        allow read, write: if true;
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // PARRAINAGE
    // ═══════════════════════════════════════════════════════════════
    match /referrals/{code} {
      allow read: if isAuth();
      allow create: if isAdmin()
        || (isAuth()
            && request.resource.data.ownerUid == request.auth.uid);
      allow update: if isAdmin()
        || (isAuth()
            && resource.data.ownerUid == request.auth.uid
            && !('ownerUid' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin();
      match /uses/{filleulUid} {
        allow read: if isAdmin()
          || (isAuth() && get(/databases/$(database)/documents/referrals/$(code)).data.ownerUid == request.auth.uid);
        allow write: if isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // LOGS DE RETENTION / RESILIATION
    // ═══════════════════════════════════════════════════════════════
    match /retention_logs/{docId} {
      allow read, write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // RAPPORTS DE DIAGNOSTIC
    // ═══════════════════════════════════════════════════════════════
    match /debug_reports/{reportId} {
      allow read:   if isAdmin();
      allow create: if isAuth()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // PROGRESSION TUTORIEL
    // ═══════════════════════════════════════════════════════════════
    match /tuto_progress/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // TICKETS SUPPORT
    // ═══════════════════════════════════════════════════════════════
    match /tickets/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
      match /list/{ticketId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) || isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // UPDATES — Nouveautés / changelog in-app
    // ═══════════════════════════════════════════════════════════════
    match /updates/{updateId} {
      allow read:  if isAdmin() || (isAuth() && resource.data.published == true);
      allow write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // TUTORIELS VIDÉO — Vidéos d'aide gérées via admin-tutos.html
    //
    // Affichées en haut de tutoriels.html. Lecture par tout utilisateur
    // connecté (contenu d'aide) ; écriture réservée à l'admin.
    // Path : tuto_videos/{videoId}
    // ═══════════════════════════════════════════════════════════════
    match /tuto_videos/{videoId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // BLOG — Drafts, Published, Topics
    // ═══════════════════════════════════════════════════════════════
    match /blog_drafts/{slug} {
      allow read, write: if isAdmin();
    }
    match /blog_published/{slug} {
      allow read, write: if isAdmin();
    }
    match /blog_topics/{topicId} {
      allow read, write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // ALTEORE CONSEIL — Profil des conseillers (comptables / coachs)
    //
    // conseillers/{uid}                — profil principal
    //   • email, displayName, cabinet, type, role='conseiller'
    //   • createdAt, lastLogin
    //
    // conseillers/{uid}/clients/{clientUid} — index inverse dénormalisé
    //   pour lister rapidement les clients du conseiller
    //   (écrit uniquement par les API serveur via admin token)
    // ═══════════════════════════════════════════════════════════════
    match /conseillers/{conseillerUid} {
      allow read:   if isOwner(conseillerUid) || isAdmin();
      allow create: if isOwner(conseillerUid) || isAdmin();
      allow update: if isOwner(conseillerUid) || isAdmin();
      allow delete: if isAdmin();
      match /clients/{clientUid} {
        allow read:  if isOwner(conseillerUid) || isAdmin();
        allow write: if isAdmin();
      }
    }
    // ═══════════════════════════════════════════════════════════════
    // ALTEORE CONSEIL — Permissions d'accès (source de vérité)
    //
    // client_access/{clientUid}/grants/{conseillerUid}
    //   • status         'active' | 'revoked' | 'expired'
    //   • expiresAt      Timestamp | null  (null = permanent)
    //   • duration       '7d' | '30d' | '90d' | 'permanent'
    //   • grantedAt      ISO string
    //   • firstAccessAt  ISO string | null  (déclenche l'email "1ère connexion")
    //   • lastAccessAt   ISO string | null
    //   • accessCount    number
    //
    // Lecture : owner du compte (pour afficher dans profil),
    //           conseiller (pour vérifier validité côté UI),
    //           admin
    // Écriture : admin uniquement (toutes les API conseil-* passent par
    //            le admin token api@altiora.app)
    // ═══════════════════════════════════════════════════════════════
    match /client_access/{clientUid}/grants/{conseillerUid} {
      allow read:  if isOwner(clientUid) || isOwner(conseillerUid) || isAdmin();
      allow write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // ALTEORE CONSEIL — Invitations en attente
    //
    // conseil_invitations/{token}
    //   Le token est un string aléatoire de 32 chars qui sert de secret
    //   dans l'URL d'invitation. La lecture est publique (le destinataire
    //   du mail clique sur le lien et arrive sur accept-invite.html qui
    //   lit l'invitation pour afficher les infos).
    //   L'écriture passe par les API serveur uniquement.
    // ═══════════════════════════════════════════════════════════════
    match /conseil_invitations/{token} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // URSSAF_CACHE — Cache partagé des taux de charges (serveur uniquement)
    //
    // Lu/écrit EXCLUSIVEMENT par api/urssaf-cost.js via le token admin
    // (api@altiora.app, pattern signInWithPassword → Bearer). Le client
    // n'y accède jamais → isAdmin() suffit, pas de scope par {uid}.
    //
    // ⚠️ Sans ce bloc, le token admin tombe dans le « REFUS PAR DEFAUT »
    // ci-dessous (le token admin est soumis aux rules comme tout user) :
    // → 403 sur chaque get/set du cache → cache mort → 100% des appels
    // tapent l'API mon-entreprise.urssaf.fr → 429 Too Many Requests → 502.
    //
    // Le wildcard récursif {document=**} couvre le doc parent
    // `barometre_{année}` ET la sous-collection `entries/{clé}`.
    // Path : urssaf_cache/barometre_{année}/entries/{clé}
    // ═══════════════════════════════════════════════════════════════
    match /urssaf_cache/{document=**} {
      allow read, write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // BACKUPS_LOG — État et journal des sauvegardes externes (cron-backup)
    //
    // Écrit par api/cron-backup.js via le token admin (api@altiora.app) :
    // un doc par jour {status, stage, uCursor, usersDone, docsTotal, ...}
    // qui permet la reprise multi-passes du cron de sauvegarde et
    // l'affichage « dernière sauvegarde OK » dans admin-backup.html.
    //
    // ⚠️ Sans ce bloc, le token admin tombe dans le REFUS PAR DEFAUT
    // → le cron ne peut pas persister son état → pas de reprise.
    // ═══════════════════════════════════════════════════════════════
    match /backups_log/{docId} {
      allow read, write: if isAdmin();
    }
    // ═══════════════════════════════════════════════════════════════
    // REFUS PAR DEFAUT
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
