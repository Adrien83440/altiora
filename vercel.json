      "maxDuration": 10
    },
    "api/fetch-sheet.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/generate-rh-doc.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/bank-connect.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/bank-sync.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cron-trial-check.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/activate-promo.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/send-welcome.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/check-promo-stripe.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/apply-referral.js": {
      "memory": 256,
