{
  "version": 2,
  "rewrites": [
    {
      "source": "/pricing",
      "destination": "/pricing.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/cgv",
      "destination": "/cgv.html"
    },
    {
      "source": "/confidentialite",
      "destination": "/confidentialite.html"
    },
    {
      "source": "/mentions-legales",
      "destination": "/mentions-legales.html"
    },
    {
      "source": "/essai-gratuit",
      "destination": "/essai-gratuit.html"
    },
    {
      "source": "/logiciel-gestion-restaurant",
      "destination": "/logiciel-gestion-restaurant.html"
    },
    {
      "source": "/logiciel-gestion-boulangerie",
      "destination": "/logiciel-gestion-boulangerie.html"
    },
    {
      "source": "/logiciel-gestion-boutique",
      "destination": "/logiciel-gestion-boutique.html"
    },
    {
      "source": "/logiciel-gestion-coiffeur",
      "destination": "/logiciel-gestion-coiffeur.html"
    },
    {
      "source": "/logiciel-gestion-artisan",
      "destination": "/logiciel-gestion-artisan.html"
    },
    {
      "source": "/logiciel-gestion-agence",
      "destination": "/logiciel-gestion-agence.html"
    },
    {
      "source": "/lea",
      "destination": "/lea.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/blog/:slug.html"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/conseil",
      "destination": "/conseil/index.html"
    },
    {
      "source": "/conseil/",
      "destination": "/conseil/index.html"
    },
    {
      "source": "/((?!api/|conseil/|_next/|_vercel/).*)",
      "has": [
        {
          "type": "host",
          "value": "conseil.alteore.com"
        }
      ],
      "destination": "/conseil/$1"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://alteore.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, stripe-signature, Authorization, x-cron-secret"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-trial-check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron-agent-memory-refresh",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron-briefing-daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron-generate-blog",
      "schedule": "0 9 * * 2,5"
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/blog.html",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/pricing.html",
      "destination": "/pricing",
      "permanent": true
    },
    {
      "source": "/login.html",
      "destination": "/login",
      "permanent": true
    },
    {
      "source": "/cgv.html",
      "destination": "/cgv",
      "permanent": true
    },
    {
      "source": "/confidentialite.html",
      "destination": "/confidentialite",
      "permanent": true
    },
    {
      "source": "/mentions-legales.html",
      "destination": "/mentions-legales",
      "permanent": true
    },
    {
      "source": "/essai-gratuit.html",
      "destination": "/essai-gratuit",
      "permanent": true
    },
    {
      "source": "/logiciel-gestion-restaurant.html",
      "destination": "/logiciel-gestion-restaurant",
      "permanent": true
    },
    {
      "source": "/logiciel-gestion-boulangerie.html",
      "destination": "/logiciel-gestion-boulangerie",
      "permanent": true
    },
    {
      "source": "/logiciel-gestion-boutique.html",
      "destination": "/logiciel-gestion-boutique",
      "permanent": true
    },
    {
      "source": "/logiciel-gestion-coiffeur.html",
      "destination": "/logiciel-gestion-coiffeur",
      "permanent": true
    },
    {
      "source": "/logiciel-gestion-artisan.html",
      "destination": "/logiciel-gestion-artisan",
      "permanent": true
    },
    {
      "source": "/logiciel-gestion-agence.html",
      "destination": "/logiciel-gestion-agence",
      "permanent": true
    }
  ]
}