    },
    "api/chatbot.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/rh-planning-ai.js": {
      "memory": 512,
      "maxDuration": 120
    },
    "api/analyze-ticket.js": {
      "memory": 256,
