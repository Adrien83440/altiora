{
  "version": 2,
  "functions": {
    "api/stripe-webhook.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/stripe-subscription-webhook.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/create-checkout.js": {
      "memory": 256
    },
    "api/create-subscription-checkout.js": {
      "memory": 256
    },
    "api/stripe-portal.js": {
      "memory": 256
    },
    "api/send-sms.js": {
      "memory": 256
    },
    "api/analyze-bilan.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/chatbot.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/rh-planning-ai.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/analyze-ticket.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/public-ca.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/public-ca-setup.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/fetch-sheet.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/generate-rh-doc.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/bank-connect.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/bank-sync.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://alteore.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, stripe-signature, Authorization"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
