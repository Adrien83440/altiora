      "maxDuration": 15
    },
    "api/public-ca.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/public-ca-setup.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/fetch-sheet.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/generate-rh-doc.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/bank-connect.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/bank-sync.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cron-trial-check.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/activate-promo.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/send-welcome.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/check-promo-stripe.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/apply-referral.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/cancel-subscription.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/apply-retention-coupon.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/generate-referral-code.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/get-invoices.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://alteore.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, stripe-signature, Authorization"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/(favicon\\.ico|favicon\\.svg|favicon-16\\.png|favicon-32\\.png|apple-touch-icon\\.png|icon-192\\.png|icon-512\\.png|og-image\\.png|site\\.webmanifest|robots\\.txt|sitemap\\.xml)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.alteore.com" }],
      "destination": "https://alteore.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "alteore.net" }],
      "destination": "https://alteore.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.alteore.net" }],
      "destination": "https://alteore.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "alteore.io" }],
      "destination": "https://alteore.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.alteore.io" }],
      "destination": "https://alteore.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "alteore.app" }],
      "destination": "https://alteore.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.alteore.app" }],
      "destination": "https://alteore.com/:path*",
      "permanent": true
    },
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true }
  ],
  "crons": [
    {
      "path": "/api/cron-trial-check",
      "schedule": "0 8 * * *"
    }
  ]
}