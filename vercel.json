    },
    "api/create-checkout.js": {
      "memory": 256
    },
    "api/create-subscription-checkout.js": {
      "memory": 256
    },
    "api/stripe-portal.js": {
      "memory": 256
    },
    "api/send-sms.js": {
      "memory": 256
    },
    "api/analyze-bilan.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/parse-releve.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/parse-invoice.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/chatbot.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/rh-planning-ai.js": {
      "memory": 512,
      "maxDuration": 120
    },
    "api/analyze-ticket.js": {
